import SwiftUI
import CoreBluetooth

struct ContentView: View {
    
    @StateObject var bluetooth = BluetoothManager()
    @State private var motorSpeed: Double = 1
    
    var body: some View {
        VStack(spacing: 20) {
            
            Text(bluetooth.isConnected ? "Connected" : "Disconnected")
                .foregroundColor(bluetooth.isConnected ? .green : .red)
                .font(.headline)
            
            if !bluetooth.foundDevices.isEmpty {
                List(bluetooth.foundDevices, id: \.identifier) { device in
                    Button(device.name ?? "Unknown Device") {
                        bluetooth.connect(to: device)
                    }
                }
                .frame(height: 150)
            }
            
            Button("Scan for HM-10") {
                bluetooth.startScanning()
            }
            .padding()
            .background(Color.blue)
            .foregroundColor(.white)
            .cornerRadius(10)
            
            Button("Forward") {
                bluetooth.sendCommand("A")
            }
            .padding()
            .frame(width: 120, height: 50)
            .background(Color.green)
            .foregroundColor(.white)
            .cornerRadius(10)
            
            HStack(spacing: 20) {
                Button("Left") {
                    bluetooth.sendCommand("D")
                }
                .padding()
                .frame(width: 100, height: 50)
                .background(Color.orange)
                .foregroundColor(.white)
                .cornerRadius(10)
                
                Button("Stop") {
                    bluetooth.sendCommand("G")
                }
                .padding()
                .frame(width: 100, height: 50)
                .background(Color.red)
                .foregroundColor(.white)
                .cornerRadius(10)
                
                Button("Right") {
                    bluetooth.sendCommand("B")
                }
                .padding()
                .frame(width: 100, height: 50)
                .background(Color.orange)
                .foregroundColor(.white)
                .cornerRadius(10)
            }
            
            Button("Backward") {
                bluetooth.sendCommand("C")
            }
            .padding()
            .frame(width: 120, height: 50)
            .background(Color.green)
            .foregroundColor(.white)
            .cornerRadius(10)
            
            VStack {
                Text("Speed: \(Int(motorSpeed))")
                    .font(.subheadline)
                Slider(value: $motorSpeed, in: 1...4, step: 1)
                    .padding(.horizontal)
                HStack {
                    Button("Stop") { bluetooth.sendCommand("G") }
                    Spacer()
                    Button("Slow") { bluetooth.sendCommand("H") }
                    Spacer()
                    Button("Medium") { bluetooth.sendCommand("F") }
                    Spacer()
                    Button("Fast") { bluetooth.sendCommand("E") }
                }
                .padding(.horizontal)
                .font(.caption)
            }
        }
        .padding()
    }
}
